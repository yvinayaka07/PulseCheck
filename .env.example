# =============================================================================
# PulseCheck – Environment Variables
# Copy this file to .env and customise for your environment.
# NEVER commit .env to version control.
# =============================================================================

# Application
APP_NAME=PulseCheck
APP_VERSION=1.0.0
APP_ENV=development

# Server
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO

# External connectivity check
EXTERNAL_CHECK_URL=https://www.github.com
EXTERNAL_CHECK_TIMEOUT=5
EXTERNAL_CHECK_RETRIES=3
