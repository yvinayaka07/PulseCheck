# =============================================================================
# PulseCheck – .gitignore
# =============================================================================

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
.env/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
*.env
!.env.example

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── Docker ────────────────────────────────────────────────────────────────────
*.tar

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
